{
  "configs": [
    {
      "title": "AMLL TTML",
      "config": "amll-ttml-settings.json",
      "preferences": [
        {
          "type": "button",
          "title": "\u624b\u52a8\u5339\u914d\u5f53\u524d\u6b4c\u66f2",
          "summary": "\u641c\u7d22 AMLL \u6b4c\u8bcd\u5e93\uff0c\u6216\u8ba9\u5f53\u524d\u6b4c\u66f2\u6539\u7528\u672c\u5730/\u5143\u6570\u636e\u6b4c\u8bcd",
          "arrow_type": "none",
          "on_click": "dev.amll.saltplayer.ttml.AmllTtmlPlugin.openManualMatcher"
        },
        {
          "type": "button",
          "title": "\u6b4c\u8bcd\u504f\u79fb\u8c03\u6574",
          "summary": "\u8bbe\u7f6e\u5168\u5c40\u6b4c\u8bcd\u65f6\u95f4\u504f\u79fb\uff0c\u6b63\u6570\u5ef6\u540e\u663e\u793a\uff0c\u8d1f\u6570\u63d0\u524d\u663e\u793a",
          "arrow_type": "none",
          "on_click": "dev.amll.saltplayer.ttml.AmllTtmlPlugin.openLyricOffsetDialog"
        },
        {
          "key": "logging.enabled",
          "type": "switch",
          "title": "\u8fd0\u884c\u65e5\u5fd7",
          "summary": "\u5f00\u542f\u540e\u8bb0\u5f55\u641c\u7d22\u3001\u5339\u914d\u3001\u8f6c\u6362\u3001\u7f13\u5b58\u548c\u56de\u9000\u95ee\u9898",
          "default_value": true
        },
        {
          "key": "logging.level",
          "type": "list",
          "title": "\u65e5\u5fd7\u8be6\u7ec6\u7a0b\u5ea6",
          "summary": "\u666e\u901a\u9002\u5408\u65e5\u5e38\u6392\u67e5\uff0c\u8be6\u7ec6\u4f1a\u989d\u5916\u8bb0\u5f55\u7f13\u5b58\u548c\u8bf7\u6c42\u7ec6\u8282",
          "entries": ["\u666e\u901a", "\u8be6\u7ec6"],
          "entry_values": ["normal", "verbose"],
          "default_value": "normal"
        },
        {
          "type": "button",
          "title": "\u6253\u5f00\u65e5\u5fd7\u76ee\u5f55",
          "summary": "\u6253\u5f00 AMLL TTML Loader \u7684\u672c\u5730\u65e5\u5fd7\u6587\u4ef6\u5939",
          "arrow_type": "none",
          "on_click": "dev.amll.saltplayer.ttml.AmllTtmlPlugin.openLogDirectory"
        },
        {
          "type": "button",
          "title": "\u6e05\u7406\u65e5\u5fd7",
          "summary": "\u5220\u9664\u5df2\u4fdd\u5b58\u7684 AMLL TTML Loader \u65e5\u5fd7\u6587\u4ef6",
          "arrow_type": "none",
          "on_click": "dev.amll.saltplayer.ttml.AmllTtmlPlugin.clearLogs"
        }
      ]
    }
  ]
}
